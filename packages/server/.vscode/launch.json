{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Zig Server",
      "program": "${workspaceFolder}/zig-out/bin/flextracker.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "zig-build-debug",
      "stopOnEntry": false,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "cppdbg",
      "request": "launch",
      "name": "Debug Zig Server (GDB)",
      "program": "${workspaceFolder}/zig-out/bin/flextracker.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "zig-build-debug",
      "stopOnEntry": false,
      "console": "integratedTerminal",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "miDebuggerPath": "gdb.exe",
      "miDebuggerArgs": ""
    }
  ]
}
